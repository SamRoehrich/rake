{
  "name": "oc-server-discovery",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "api:dev": "bun run index.ts",
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "web:start": "bun run --cwd apps/web start",
    "auth:generate": "bunx --bun auth@latest generate \
      --config ./src/lib/auth.ts \
      --output ./src/services/database/auth-schema.ts \
      --yes"
  },
  "devDependencies": {
    "@effect/language-service": "^0.73.1",
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^1.0.0-beta.15-859cf75",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/sql": "^0.49.0",
    "@effect/sql-pg": "^0.50.3",
    "@opencode-ai/sdk": "^1.2.10",
    "@types/dockerode": "^4.0.1",
    "better-auth": "^1.5.0",
    "dockerode": "^4.0.9",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^1.0.0-beta.15-859cf75",
    "effect": "^3.19.19",
    "pg": "^8.19.0"
  }
}
